# ============================================================
# Polymarket Sports Arbitrage Bot — Environment Variables
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control.
# ============================================================

# --- Polymarket Wallet ---
POLYMARKET_PRIVATE_KEY=0x
SIGNATURE_TYPE=0
FUNDER_ADDRESS=
POLYMARKET_HOST=https://clob.polymarket.com
CHAIN_ID=137

# --- Anthropic Claude AI ---
ANTHROPIC_API_KEY=sk-ant-
AI_MODEL=claude-haiku-4-5-20251001
AI_MAX_CANDIDATES=2
AI_MIN_EDGE_PCT=6.0
AI_SKIP_CACHE_TTL=600
AI_PAPER_MODE=gate

# --- The Odds API (optional) ---
ODDS_API_KEY=

# --- Trading Parameters ---
MIN_EDGE_PCT=2.0
MIN_AI_CONFIDENCE=0.70
BET_SIZE_PCT=2.0
INITIAL_BET_SIZE=2.0
MAX_BET_SIZE=50.0
MAX_EXPOSURE_PCT=30.0
ENABLE_SAME_MARKET_ARB=true
ENABLE_SAME_MARKET_EXECUTION=false
ENABLE_CROSS_MARKET_ARB=false
ENABLE_ODDS_COMPARISON_ARB=true
ODDS_COMPARISON_MONEYLINE_ONLY=true

# --- Safety ---
PAPER_TRADING=true
POLL_INTERVAL=7
LOG_LEVEL=INFO
RESET_STATE_ON_START=false
RESET_LOGS_ON_START=true
