# ============================================================
# Polymarket Sports Arbitrage Bot — Environment Variables
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control.
# ============================================================

# --- Polymarket Wallet ---
POLYMARKET_PRIVATE_KEY=0x
SIGNATURE_TYPE=0
FUNDER_ADDRESS=
POLYMARKET_HOST=https://clob.polymarket.com
CHAIN_ID=137

# --- Anthropic Claude AI ---
ANTHROPIC_API_KEY=sk-ant-
AI_MODEL=claude-haiku-4-5-20251001
AI_MAX_CANDIDATES=2
AI_SCAN_LIMIT=5
AI_MIN_EDGE_PCT=6.0
AI_SKIP_CACHE_TTL=600
AI_PAPER_MODE=gate

# --- The Odds API (optional) ---
ODDS_API_KEY=
SPORTMONKS_API_KEY=
SPORTMONKS_API_BASE=https://api.sportmonks.com/v3/football
API_FOOTBALL_API_KEY=
API_FOOTBALL_API_BASE=https://v3.football.api-sports.io

# --- Trading Parameters ---
MIN_EDGE_PCT=2.0
MIN_AI_CONFIDENCE=0.70
BET_SIZE_PCT=2.0
INITIAL_BET_SIZE=2.0
MAX_BET_SIZE=50.0
MAX_EXPOSURE_PCT=30.0
ENABLE_SAME_MARKET_ARB=true
ENABLE_SAME_MARKET_EXECUTION=false
ENABLE_CROSS_MARKET_ARB=false
ENABLE_ODDS_COMPARISON_ARB=true
ODDS_COMPARISON_MONEYLINE_ONLY=true
ODDS_COMPARISON_MIN_PRICE=0.05
MATCH_ANALYTICS_ENABLED=true
MATCH_DATA_PROVIDERS=sportmonks,api_football,sportsbook_only
MATCH_ANALYTICS_CACHE_TTL=900
MATCH_LOOKBACK_DAYS=365
MATCH_LOOKBACK_MATCHES=8
MATCH_RECENCY_DECAY=0.82
MATCH_HOME_ADVANTAGE=0.12
MATCH_XG_PER_SHOT_ON_TARGET=0.32
MATCH_LINEUP_ABSENCE_PENALTY=0.025
MATCH_HEAD_TO_HEAD_WEIGHT=0.03
SPORTMONKS_DAILY_LIMIT=0
API_FOOTBALL_DAILY_LIMIT=100

# --- Safety ---
PAPER_TRADING=true
POLL_INTERVAL=7
LOG_LEVEL=INFO
RESET_STATE_ON_START=false
RESET_LOGS_ON_START=true
REALTIME_MARKET_WS_ENABLED=true
REALTIME_MARKET_WS_MAX_ASSETS=400
REALTIME_MARKET_WS_MAX_HOURS_TO_EXPIRY=24
REALTIME_MARKET_WS_QUOTE_TTL_SECONDS=12
REALTIME_MARKET_WS_BOOK_TTL_SECONDS=20
ENABLE_REALTIME_EXECUTION_GATE=true
REALTIME_GATE_MAX_SPREAD=0.15
REALTIME_GATE_MIN_DEPTH_USD=5.0
